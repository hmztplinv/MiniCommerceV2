{
  "info": {
    "name": "MiniCommerceV2",
    "description": "MiniCommerceV2 microservices learning project collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Identity",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{identityBaseUrl}}/health",
              "host": [
                "{{identityBaseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman.user@example.com\",\n  \"password\": \"Password123\",\n  \"fullName\": \"Postman User\"\n}"
            },
            "url": {
              "raw": "{{identityBaseUrl}}/api/auth/register",
              "host": [
                "{{identityBaseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (response.accessToken) {",
                  "    pm.environment.set('jwtToken', response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hamza@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{identityBaseUrl}}/api/auth/login",
              "host": [
                "{{identityBaseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hamza@example.com\",\n  \"password\": \"WrongPassword123\"\n}"
            },
            "url": {
              "raw": "{{identityBaseUrl}}/api/auth/login",
              "host": [
                "{{identityBaseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{identityBaseUrl}}/api/users/me",
              "host": [
                "{{identityBaseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          }
        }
      ]
    }
  ]
}
